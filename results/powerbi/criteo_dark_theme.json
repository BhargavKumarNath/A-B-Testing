{
    "name": "Criteo Premium Dark",
    "dataColors": [
        "#3B82F6",
        "#10B981",
        "#F59E0B",
        "#EF4444",
        "#8B5CF6",
        "#14B8A6",
        "#6366F1",
        "#EC4899"
    ],
    "background": "#0F172A",
    "foreground": "#F8FAFC",
    "tableAccent": "#3B82F6",
    "visualStyles": {
        "page": {
            "*": {
                "background": [{ "color": {"solid": {"color": "#0F172A"}}, "transparency": 0 }],
                "outspace": [{ "color": {"solid": {"color": "#000000"}} }]
            }
        },
        "*": {
            "*": {
                "background": [{ "show": true, "color": {"solid": {"color": "#1E293B"}}, "transparency": 0 }],
                "visualHeader": [{ "show": true }],
                "border": [{ "show": false }],
                "dropShadow": [{ "show": true, "color": {"solid": {"color": "#000000"}}, "position": "Outer", "blur": 15, "transparency": 60 }]
            }
        },
        "card": {
            "*": {
                "labels": [{
                    "color": {"solid": {"color": "#F8FAFC"}},
                    "fontSize": 26,
                    "fontFamily": "DIN"
                }],
                "categoryAxis": [{
                    "color": {"solid": {"color": "#94A3B8"}},
                    "fontSize": 12,
                    "fontFamily": "Segoe UI",
                    "show": true
                }]
            }
        },
        "scatterChart": {
            "*": {
                "general": [{ "responsive": true }],
                "legend": [{ "show": true, "position": "TopCenter", "titleText": "", "fontColor": {"solid": {"color": "#F8FAFC"}} }],
                "categoryAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }],
                "valueAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }]
            }
        },
        "lineChart": {
            "*": {
                "legend": [{ "show": true, "position": "TopCenter", "titleText": "", "fontColor": {"solid": {"color": "#F8FAFC"}} }],
                "categoryAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }],
                "valueAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }]
            }
        },
        "columnChart": {
            "*": {
                "legend": [{ "show": true, "position": "TopCenter", "titleText": "", "fontColor": {"solid": {"color": "#F8FAFC"}} }],
                "categoryAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}} }],
                "valueAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }]
            }
        },
        "barChart": {
            "*": {
                "legend": [{ "show": true, "position": "TopCenter", "titleText": "", "fontColor": {"solid": {"color": "#F8FAFC"}} }],
                "categoryAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}}, "gridlineStyle": "dotted", "gridlineColor": {"solid": {"color": "#334155"}} }],
                "valueAxis": [{ "show": true, "labelColor": {"solid": {"color": "#94A3B8"}} }]
            }
        },
        "tableEx": {
            "*": {
                "grid": [{ "gridVertical": false, "gridHorizontal": true, "gridHorizontalColor": {"solid": {"color": "#334155"}}, "gridHorizontalWeight": 1 }],
                "columnHeaders": [{ "fontColor": {"solid": {"color": "#F8FAFC"}}, "backColor": {"solid": {"color": "#1E293B"}}, "fontFamily": "Segoe UI Semibold" }],
                "values": [{ "fontColorPrimary": {"solid": {"color": "#F8FAFC"}}, "backColorPrimary": {"solid": {"color": "#1E293B"}}, "fontColorSecondary": {"solid": {"color": "#F8FAFC"}}, "backColorSecondary": {"solid": {"color": "#0F172A"}}, "fontFamily": "Segoe UI" }]
            }
        }
    }
}
